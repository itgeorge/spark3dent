spark3dent.com {
    encode gzip zstd

    # 1) oauth2-proxy endpoints (must be reachable)
    handle /oauth2/* {
        reverse_proxy oauth2-proxy:4180
    }

    # 2) Protected app routes
    @protected {
        not path /oauth2/*
    }

    handle @protected {
        forward_auth oauth2-proxy:4180 {
            uri /oauth2/auth
            copy_headers X-Auth-Request-Email X-Auth-Request-User Authorization

            # If NOT authenticated, redirect into oauth2-proxy's login flow
            @unauthenticated status 401
            handle_response @unauthenticated {
                header Cache-Control "no-store"
                redir * /oauth2/start?rd={http.request.uri}
            }
        }

        reverse_proxy web:8080
    }

    # 3) Fail closed: anything not matched above is forbidden
    respond 403
}

www.spark3dent.com {
    redir https://spark3dent.com{http.request.uri} permanent
}
